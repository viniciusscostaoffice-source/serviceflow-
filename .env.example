# VITE_WEBHOOK_URL: Webhook url to receive lead form submissions (e.g. Make, Zapier)
VITE_WEBHOOK_URL="https://your-webhook-url.com/webhook"

# VITE_CHECKOUT_URL: Link to checkout (e.g. Asaas, Stripe)
VITE_CHECKOUT_URL="https://checkout.asaas.com/...."

# VITE_META_PIXEL_ID: Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID="YOUR_PIXEL_ID"

# VITE_GA_ID: Google Analytics 4 ID
VITE_GA_ID="G-XXXXXXXXXX"

# VITE_WHATSAPP_NUMBER: WhatsApp number for the floating button and footer
VITE_WHATSAPP_NUMBER="5511999999999"

# Supabase Auth and DB mapping
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Abacatepay — configurar nos Secrets do Supabase Edge Functions (NUNCA no .env do frontend)
# ABACATEPAY_API_KEY="abacate_live_..."
# ABACATEPAY_WEBHOOK_PUBLIC_KEY="chave-publica-do-webhook-abacatepay"
